{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whispery",
  "version": "0.1.0",
  "identifier": "com.christiantrummer.whispery",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Whispery",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "visible": true,
        "titleBarStyle": "Transparent",
        "backgroundColor": [255, 255, 255, 255]
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay",
        "width": 220,
        "height": 52,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "x": 40,
        "y": 40
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Whispery - Push to Talk"
    },
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ChristianTrummer99/whispery/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
